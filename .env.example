PORT=4000
AUTH_TOKEN=fake-token

# local keeps everything in-process.
# bullmq persists delayed jobs, retries, failures, and queue state in Redis.
QUEUE_DRIVER=bullmq
REDIS_HOST=localhost
REDIS_PORT=6379

LISTING_PROCESSING_DELAY_MS=5000
DATABASE_URL="postgresql://amazon:amazon@localhost:5433/amazon_emulator?schema=public"
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

WEBHOOK_MAX_ATTEMPTS=3
WEBHOOK_RETRY_DELAY_MS=1000
WEBHOOK_TIMEOUT_MS=3000

# Format:
# METHOD:/path-prefix:probability:kind
# Example:
# ERROR_SIMULATION_RULES=PUT:/listings:0.05:503,GET:/inventory:0.02:timeout
ERROR_SIMULATION_RULES=
